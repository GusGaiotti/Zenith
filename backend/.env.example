SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/zenith_dev
DB_USERNAME=postgres
DB_PASSWORD=change-me

JWT_SECRET=replace-with-a-base64-secret-at-least-32-bytes-when-decoded
