AI_MODE=local
AI_TIMEOUT_MS=8000
AI_MAX_RESPONSE_TOKENS=300
AI_LIMITS_ENABLED=true
AI_RATE_LIMIT_PER_USER=8
AI_RATE_LIMIT_PER_IP=20
AI_DAILY_QUOTA_PER_USER=50

